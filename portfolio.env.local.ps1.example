# Optional local environment settings for the portfolio Python server.
# Rename this file to: portfolio.env.local.ps1
# Then fill your real values and run .\start-server.ps1

# SMTP provider presets supported by server.py: gmail | outlook | zoho
$env:PORTFOLIO_SMTP_PROVIDER = ''

# If not using provider presets, set custom SMTP host/port/TLS values directly.
$env:PORTFOLIO_SMTP_HOST = ''
$env:PORTFOLIO_SMTP_PORT = '587'
$env:PORTFOLIO_SMTP_STARTTLS = 'true'
$env:PORTFOLIO_SMTP_SSL = 'false'

# SMTP credentials (prefer storing password in Credential Manager target: portfolio/smtp-password)
$env:PORTFOLIO_SMTP_USERNAME = ''
$env:PORTFOLIO_SMTP_PASSWORD = ''
$env:PORTFOLIO_SMTP_FROM = ''

# One or more recipients (comma-separated)
$env:PORTFOLIO_SMTP_TO = ''

# Admin auth options:
# 1) Plain token (recommended to store in Credential Manager target: portfolio/admin-token)
$env:PORTFOLIO_ADMIN_TOKEN = ''
# 2) Hashed token (pbkdf2_sha256$iterations$salt_hex$hash_hex), optional.
#    Recommended to store in Credential Manager target: portfolio/admin-token-hash
$env:PORTFOLIO_ADMIN_TOKEN_HASH = ''

# Force admin API routes to require token auth (recommended for LAN/public use)
$env:PORTFOLIO_ADMIN_REQUIRE_TOKEN = 'false'

# Enable Strict-Transport-Security header when serving over HTTPS
$env:PORTFOLIO_ENABLE_HSTS = 'false'

# Cache-Control max-age for static assets (seconds)
$env:PORTFOLIO_STATIC_CACHE_MAX_AGE_SECONDS = '604800'

# Optional monitoring alert webhook
$env:PORTFOLIO_ALERT_WEBHOOK_URL = ''

# Optional spam protection tuning
$env:PORTFOLIO_CONTACT_RATE_LIMIT_MAX_REQUESTS = '5'
$env:PORTFOLIO_CONTACT_RATE_LIMIT_WINDOW_SECONDS = '300'
