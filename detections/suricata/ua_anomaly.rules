#
# Suricata Rules — Anomalous HTTP User-Agent Patterns
# Author:  Azhad Shahzad Shaik
# Date:    2026-05-24
# Engine:  signature (NIDS hybrid pipeline)
# ATT&CK:  T1071.001 Application Layer Protocol: Web Protocols
#
# Tuning: each rule has a per-environment allowlist comment. Replace the
# placeholder IPs/UA strings with your fleet's actual signed-agent UAs.
#

# --- Rule 1: HTTP request with empty or zero-length User-Agent --------------------------
# Many implants forget the UA header entirely (or send "User-Agent: ") on first beacon.
# Healthy traffic always carries something; an empty UA from an external destination
# behind a real browser session is suspicious.
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"DETECTION Anomaly Outbound HTTP with Empty User-Agent";
    flow:established,to_server;
    http.user_agent; isdataat:!1,relative;
    classtype:trojan-activity;
    metadata: attack_id T1071.001, engine signature, confidence medium;
    reference:url,attack.mitre.org/techniques/T1071/001/;
    sid:9000001; rev:1;
)

# --- Rule 2: Outbound HTTP with python-requests / curl / wget UA from non-admin host ---
# These UAs are normal from build agents and admin jumphosts. From a regular user
# workstation they are usually scripted activity worth pivoting on. Restrict to
# the user-workstation subnet via $HOME_NET narrowing in suricata.yaml, or extend
# this rule with an excluded source CIDR using ip-list.
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"DETECTION Anomaly Scripted HTTP Client UA from User Subnet";
    flow:established,to_server;
    http.user_agent; content:"python-requests/"; startswith;
    classtype:policy-violation;
    metadata: attack_id T1071.001, engine signature, confidence low;
    sid:9000002; rev:1;
)
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"DETECTION Anomaly curl UA from User Subnet";
    flow:established,to_server;
    http.user_agent; content:"curl/"; startswith;
    classtype:policy-violation;
    metadata: attack_id T1071.001, engine signature, confidence low;
    sid:9000003; rev:1;
)

# --- Rule 3: Outbound HTTP UA matches known offensive-tool defaults --------------------
# Cobalt Strike Malleable C2 default profile, MetaSploit auxiliary scanners,
# Sliver default UA. Real engagements will custom-roll, but defaults still ship.
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"DETECTION Offensive Tool Default UA — Cobalt Strike Malleable C2";
    flow:established,to_server;
    http.user_agent; content:"Mozilla/5.0 (compatible; MSIE 9.0; Windows NT 6.1; WOW64; Trident/5.0)";
    classtype:trojan-activity;
    metadata: attack_id T1071.001, engine signature, confidence high;
    sid:9000004; rev:1;
)
alert http $HOME_NET any -> $EXTERNAL_NET any (
    msg:"DETECTION Offensive Tool Default UA — Metasploit Auxiliary Scanner";
    flow:established,to_server;
    http.user_agent; content:"Mozilla/4.0 (compatible; MSIE 6.0; Windows NT 5.1)";
    classtype:trojan-activity;
    metadata: attack_id T1071.001, engine signature, confidence medium;
    sid:9000005; rev:1;
)
