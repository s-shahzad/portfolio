# Staging environment settings for validation deployments.
# Copy to: portfolio.env.staging.ps1

# Admin auth (use token hash in staging when possible)
$env:PORTFOLIO_ADMIN_TOKEN = ''
$env:PORTFOLIO_ADMIN_TOKEN_HASH = ''
$env:PORTFOLIO_ADMIN_REQUIRE_TOKEN = 'true'

# HTTPS/security behavior
$env:PORTFOLIO_ENABLE_HSTS = 'false'
$env:PORTFOLIO_STATIC_CACHE_MAX_AGE_SECONDS = '3600'

# Optional alerting webhook
$env:PORTFOLIO_ALERT_WEBHOOK_URL = ''

# Spam controls
$env:PORTFOLIO_CONTACT_RATE_LIMIT_MAX_REQUESTS = '5'
$env:PORTFOLIO_CONTACT_RATE_LIMIT_WINDOW_SECONDS = '300'
