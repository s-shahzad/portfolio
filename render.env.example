# Copy these values into the Render service Environment page.
# Do not commit real secrets in a tracked file.

PORTFOLIO_ADMIN_REQUIRE_TOKEN=true
PORTFOLIO_ADMIN_TOKEN_HASH=<paste the value from scripts/credential-manager.ps1 -GetTarget 'portfolio/admin-token-hash'>

PORTFOLIO_SMTP_PROVIDER=gmail
PORTFOLIO_SMTP_USERNAME=shaikazhadshahzad@gmail.com
PORTFOLIO_SMTP_PASSWORD=<real gmail app password>
PORTFOLIO_SMTP_FROM=shaikazhadshahzad@gmail.com
PORTFOLIO_SMTP_TO=shaikazhadshahzad@gmail.com

PORTFOLIO_ENABLE_HSTS=true
PORTFOLIO_STATIC_CACHE_MAX_AGE_SECONDS=604800
PORTFOLIO_CONTACT_RATE_LIMIT_MAX_REQUESTS=5
PORTFOLIO_CONTACT_RATE_LIMIT_WINDOW_SECONDS=300
